<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="Policy"/>
          <swrl:argument1 rdf:resource="p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <swrl:AtomList>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="hasGrantType"/>
              <swrl:argument1 rdf:resource="p"/>
              <swrl:argument2 rdf:resource="PermissionGrant"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <swrl:AtomList>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="hasGrantLevel"/>
                  <swrl:argument1 rdf:resource="p"/>
                  <swrl:argument2 rdf:resource="ColumnLevel"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <swrl:AtomList>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="hasAgent"/>
                      <swrl:argument1 rdf:resource="p"/>
                      <swrl:argument2 rdf:resource="agent"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <swrl:AtomList>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="hasAction"/>
                          <swrl:argument1 rdf:resource="p"/>
                          <swrl:argument2 rdf:resource="ReadAction"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <swrl:AtomList>
                          <rdf:first>
                            <swrl:IndividualPropertyAtom>
                              <swrl:propertyPredicate rdf:resource="appliesToScope"/>
                              <swrl:argument1 rdf:resource="p"/>
                              <swrl:argument2 rdf:resource="ProcessActionScope"/>
                            </swrl:IndividualPropertyAtom>
                          </rdf:first>
                          <rdf:rest>
                            <swrl:AtomList>
                              <rdf:first>
                                <swrl:IndividualPropertyAtom>
                                  <swrl:propertyPredicate rdf:resource="controlAccessTo"/>
                                  <swrl:argument1 rdf:resource="p"/>
                                  <swrl:argument2 rdf:resource="col"/>
                                </swrl:IndividualPropertyAtom>
                              </rdf:first>
                              <rdf:rest>
                                <swrl:AtomList>
                                  <rdf:first>
                                    <swrl:ClassAtom>
                                      <swrl:classPredicate rdf:resource="ColumnRef"/>
                                      <swrl:argument1 rdf:resource="ref"/>
                                    </swrl:ClassAtom>
                                  </rdf:first>
                                  <rdf:rest>
                                    <swrl:AtomList>
                                      <rdf:first>
                                        <swrl:IndividualPropertyAtom>
                                          <swrl:propertyPredicate rdf:resource="referencesToColumn"/>
                                          <swrl:argument1 rdf:resource="ref"/>
                                          <swrl:argument2 rdf:resource="col"/>
                                        </swrl:IndividualPropertyAtom>
                                      </rdf:first>
                                      <rdf:rest>
                                        <swrl:AtomList>
                                          <rdf:first>
                                            <swrl:ClassAtom>
                                              <swrl:classPredicate rdf:resource="Statement"/>
                                              <swrl:argument1 rdf:resource="stmt"/>
                                            </swrl:ClassAtom>
                                          </rdf:first>
                                          <rdf:rest>
                                            <swrl:AtomList>
                                              <rdf:first>
                                                <swrl:IndividualPropertyAtom>
                                                  <swrl:propertyPredicate rdf:resource="representsAction"/>
                                                  <swrl:argument1 rdf:resource="stmt"/>
                                                  <swrl:argument2 rdf:resource="ReadAction"/>
                                                </swrl:IndividualPropertyAtom>
                                              </rdf:first>
                                              <rdf:rest>
                                                <swrl:AtomList>
                                                  <rdf:first>
                                                    <swrl:IndividualPropertyAtom>
                                                      <swrl:propertyPredicate rdf:resource="executedBy"/>
                                                      <swrl:argument1 rdf:resource="stmt"/>
                                                      <swrl:argument2 rdf:resource="agent"/>
                                                    </swrl:IndividualPropertyAtom>
                                                  </rdf:first>
                                                  <rdf:rest>
                                                    <swrl:AtomList>
                                                      <rdf:first>
                                                        <swrl:IndividualPropertyAtom>
                                                          <swrl:propertyPredicate rdf:resource="hasChildNode"/>
                                                          <swrl:argument1 rdf:resource="stmt"/>
                                                          <swrl:argument2 rdf:resource="clause"/>
                                                        </swrl:IndividualPropertyAtom>
                                                      </rdf:first>
                                                      <rdf:rest>
                                                        <swrl:AtomList>
                                                          <rdf:first>
                                                            <swrl:ClassAtom>
                                                              <swrl:classPredicate rdf:resource="Clause"/>
                                                              <swrl:argument1 rdf:resource="clause"/>
                                                            </swrl:ClassAtom>
                                                          </rdf:first>
                                                          <rdf:rest>
                                                            <swrl:AtomList>
                                                              <rdf:first>
                                                                <swrl:IndividualPropertyAtom>
                                                                  <swrl:propertyPredicate rdf:resource="hasChildNode"/>
                                                                  <swrl:argument1 rdf:resource="clause"/>
                                                                  <swrl:argument2 rdf:resource="ref"/>
                                                                </swrl:IndividualPropertyAtom>
                                                              </rdf:first>
                                                              <rdf:rest>
                                                                <swrl:AtomList>
                                                                  <rdf:first>
                                                                    <swrl:IndividualPropertyAtom>
                                                                      <swrl:propertyPredicate rdf:resource="hasEffectiveScope"/>
                                                                      <swrl:argument1 rdf:resource="clause"/>
                                                                      <swrl:argument2 rdf:resource="ViewActionScope"/>
                                                                    </swrl:IndividualPropertyAtom>
                                                                  </rdf:first>
                                                                  <rdf:rest>
                                                                    <swrl:AtomList>
                                                                      <rdf:first>
                                                                        <swrl:ClassAtom>
                                                                          <swrl:classPredicate rdf:resource="NonFunctional"/>
                                                                          <swrl:argument1 rdf:resource="fnode"/>
                                                                        </swrl:ClassAtom>
                                                                      </rdf:first>
                                                                      <rdf:rest>
                                                                        <swrl:AtomList>
                                                                          <rdf:first>
                                                                            <swrl:IndividualPropertyAtom>
                                                                              <swrl:propertyPredicate rdf:resource="immediateParentNode"/>
                                                                              <swrl:argument1 rdf:resource="ref"/>
                                                                              <swrl:argument2 rdf:resource="fnode"/>
                                                                            </swrl:IndividualPropertyAtom>
                                                                          </rdf:first>
                                                                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                        </swrl:AtomList>
                                                                      </rdf:rest>
                                                                    </swrl:AtomList>
                                                                  </rdf:rest>
                                                                </swrl:AtomList>
                                                              </rdf:rest>
                                                            </swrl:AtomList>
                                                          </rdf:rest>
                                                        </swrl:AtomList>
                                                      </rdf:rest>
                                                    </swrl:AtomList>
                                                  </rdf:rest>
                                                </swrl:AtomList>
                                              </rdf:rest>
                                            </swrl:AtomList>
                                          </rdf:rest>
                                        </swrl:AtomList>
                                      </rdf:rest>
                                    </swrl:AtomList>
                                  </rdf:rest>
                                </swrl:AtomList>
                              </rdf:rest>
                            </swrl:AtomList>
                          </rdf:rest>
                        </swrl:AtomList>
                      </rdf:rest>
                    </swrl:AtomList>
                  </rdf:rest>
                </swrl:AtomList>
              </rdf:rest>
            </swrl:AtomList>
          </rdf:rest>
        </swrl:AtomList>
      </rdf:rest>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="hasAlignmentState"/>
          <swrl:argument1 rdf:resource="ref"/>
          <swrl:argument2 rdf:resource="Violated"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if a column is defined under process level permission grant and it uses in viewscope clause without a parent of functional node in a readaction, then that column reference is map with violated node</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S11</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="WhereClause"/>
          <swrl:argument1 rdf:resource="x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="hasEffectiveScope"/>
          <swrl:argument1 rdf:resource="x"/>
          <swrl:argument2 rdf:resource="ProcessActionScope"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">where clause -&gt; process action</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S4</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="UpdateStatement"/>
          <swrl:argument1 rdf:resource="x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="representsAction"/>
          <swrl:argument1 rdf:resource="x"/>
          <swrl:argument2 rdf:resource="UpdateAction"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tag all Update Statements as UpdateAction</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S6</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="SelectStatement"/>
          <swrl:argument1 rdf:resource="x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="representsAction"/>
          <swrl:argument1 rdf:resource="x"/>
          <swrl:argument2 rdf:resource="ReadAction"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tag all select statements as ReadActions  tag all select statements as ReadActions</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S5</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="SelectClause"/>
          <swrl:argument1 rdf:resource="x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="hasEffectiveScope"/>
          <swrl:argument1 rdf:resource="x"/>
          <swrl:argument2 rdf:resource="ViewActionScope"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">select clause -&gt; to view action</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S1</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="Policy"/>
          <swrl:argument1 rdf:resource="p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <swrl:AtomList>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="hasAgent"/>
              <swrl:argument1 rdf:resource="p"/>
              <swrl:argument2 rdf:resource="agent"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <swrl:AtomList>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="hasGrantLevel"/>
                  <swrl:argument1 rdf:resource="p"/>
                  <swrl:argument2 rdf:resource="TableLevel"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <swrl:AtomList>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="hasGrantType"/>
                      <swrl:argument1 rdf:resource="p"/>
                      <swrl:argument2 rdf:resource="PermissionGrant"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <swrl:AtomList>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="hasAction"/>
                          <swrl:argument1 rdf:resource="p"/>
                          <swrl:argument2 rdf:resource="action"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <swrl:AtomList>
                          <rdf:first>
                            <swrl:IndividualPropertyAtom>
                              <swrl:propertyPredicate rdf:resource="controlAccessTo"/>
                              <swrl:argument1 rdf:resource="p"/>
                              <swrl:argument2 rdf:resource="t"/>
                            </swrl:IndividualPropertyAtom>
                          </rdf:first>
                          <rdf:rest>
                            <swrl:AtomList>
                              <rdf:first>
                                <swrl:ClassAtom>
                                  <swrl:classPredicate rdf:resource="TableRef"/>
                                  <swrl:argument1 rdf:resource="r"/>
                                </swrl:ClassAtom>
                              </rdf:first>
                              <rdf:rest>
                                <swrl:AtomList>
                                  <rdf:first>
                                    <swrl:IndividualPropertyAtom>
                                      <swrl:propertyPredicate rdf:resource="referencesToTable"/>
                                      <swrl:argument1 rdf:resource="r"/>
                                      <swrl:argument2 rdf:resource="t"/>
                                    </swrl:IndividualPropertyAtom>
                                  </rdf:first>
                                  <rdf:rest>
                                    <swrl:AtomList>
                                      <rdf:first>
                                        <swrl:IndividualPropertyAtom>
                                          <swrl:propertyPredicate rdf:resource="representsAction"/>
                                          <swrl:argument1 rdf:resource="stmt"/>
                                          <swrl:argument2 rdf:resource="action"/>
                                        </swrl:IndividualPropertyAtom>
                                      </rdf:first>
                                      <rdf:rest>
                                        <swrl:AtomList>
                                          <rdf:first>
                                            <swrl:IndividualPropertyAtom>
                                              <swrl:propertyPredicate rdf:resource="executedBy"/>
                                              <swrl:argument1 rdf:resource="stmt"/>
                                              <swrl:argument2 rdf:resource="agent"/>
                                            </swrl:IndividualPropertyAtom>
                                          </rdf:first>
                                          <rdf:rest>
                                            <swrl:AtomList>
                                              <rdf:first>
                                                <swrl:IndividualPropertyAtom>
                                                  <swrl:propertyPredicate rdf:resource="hasChildNode"/>
                                                  <swrl:argument1 rdf:resource="stmt"/>
                                                  <swrl:argument2 rdf:resource="r"/>
                                                </swrl:IndividualPropertyAtom>
                                              </rdf:first>
                                              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </swrl:AtomList>
                                          </rdf:rest>
                                        </swrl:AtomList>
                                      </rdf:rest>
                                    </swrl:AtomList>
                                  </rdf:rest>
                                </swrl:AtomList>
                              </rdf:rest>
                            </swrl:AtomList>
                          </rdf:rest>
                        </swrl:AtomList>
                      </rdf:rest>
                    </swrl:AtomList>
                  </rdf:rest>
                </swrl:AtomList>
              </rdf:rest>
            </swrl:AtomList>
          </rdf:rest>
        </swrl:AtomList>
      </rdf:rest>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="hasAlignmentState"/>
          <swrl:argument1 rdf:resource="r"/>
          <swrl:argument2 rdf:resource="Aligned"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tag table references are permitted when at least one or few policies.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S10</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="Policy"/>
          <swrl:argument1 rdf:resource="p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <swrl:AtomList>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="hasGrantLevel"/>
              <swrl:argument1 rdf:resource="p"/>
              <swrl:argument2 rdf:resource="TableLevel"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <swrl:AtomList>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="hasGrantType"/>
                  <swrl:argument1 rdf:resource="p"/>
                  <swrl:argument2 rdf:resource="ProhibitionGrant"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <swrl:AtomList>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="appliesToScope"/>
                      <swrl:argument1 rdf:resource="p"/>
                      <swrl:argument2 rdf:resource="ProcessActionScope"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <swrl:AtomList>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="controlAccessTo"/>
                          <swrl:argument1 rdf:resource="p"/>
                          <swrl:argument2 rdf:resource="t"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <swrl:AtomList>
                          <rdf:first>
                            <swrl:ClassAtom>
                              <swrl:classPredicate rdf:resource="Table"/>
                              <swrl:argument1 rdf:resource="t"/>
                            </swrl:ClassAtom>
                          </rdf:first>
                          <rdf:rest>
                            <swrl:AtomList>
                              <rdf:first>
                                <swrl:IndividualPropertyAtom>
                                  <swrl:propertyPredicate rdf:resource="hasColumn"/>
                                  <swrl:argument1 rdf:resource="t"/>
                                  <swrl:argument2 rdf:resource="c"/>
                                </swrl:IndividualPropertyAtom>
                              </rdf:first>
                              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </swrl:AtomList>
                          </rdf:rest>
                        </swrl:AtomList>
                      </rdf:rest>
                    </swrl:AtomList>
                  </rdf:rest>
                </swrl:AtomList>
              </rdf:rest>
            </swrl:AtomList>
          </rdf:rest>
        </swrl:AtomList>
      </rdf:rest>
    </swrl:AtomList>
  </swrl:body>
  <swrl:head>
    <swrl:AtomList>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="controlAccessTo"/>
          <swrl:argument1 rdf:resource="p"/>
          <swrl:argument2 rdf:resource="c"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest>
        <swrl:AtomList>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="hasGrantLevel"/>
              <swrl:argument1 rdf:resource="p"/>
              <swrl:argument2 rdf:resource="ColumnLevel"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </swrl:AtomList>
      </rdf:rest>
    </swrl:AtomList>
  </swrl:head>
  <swrl2:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl2:isRuleEnabled>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">where there is a policy defined for table level prohibition grant for process scope, then add all the column under those tables as controlAccessTo property</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S12</rdfs:label>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <swrl:AtomList>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="Policy"/>
          <swrl:argument1 rdf:resource="p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <swrl:AtomList>
