@prefix : <http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/> .

<http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/AgentID
:AgentID rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ColumnName
:ColumnName rdf:type owl:AnnotationProperty ;
            rdfs:range xsd:string .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/DatabaseName
:DatabaseName rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/TableName
:TableName rdf:type owl:AnnotationProperty ;
           rdfs:range xsd:string .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/columnOfTable
:columnOfTable rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/allowedGrantLevel
:allowedGrantLevel rdf:type owl:ObjectProperty ;
                   rdfs:domain :GrantType ;
                   rdfs:range :GrantLevel .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/allowsClause
:allowsClause rdf:type owl:ObjectProperty ;
              rdfs:domain :SQLNode ,
                          :Statement ;
              rdfs:range :Clause ,
                         :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/appliesToScope
:appliesToScope rdf:type owl:ObjectProperty ;
                rdfs:domain :Policy ;
                rdfs:range :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/belongsToStatement
:belongsToStatement rdf:type owl:ObjectProperty ;
                    rdfs:domain :SQLNode ;
                    rdfs:range :SQLNode ,
                               :Statement .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/columnOfTable
:columnOfTable rdf:type owl:ObjectProperty ;
               owl:inverseOf :hasColumn .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/controlAccessTo
:controlAccessTo rdf:type owl:ObjectProperty ;
                 rdfs:domain :Policy ;
                 rdfs:range :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/executedBy
:executedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :SQLNode ,
                        :Statement ;
            rdfs:range :Agent .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasAction
:hasAction rdf:type owl:ObjectProperty ;
           rdfs:domain :Policy ;
           rdfs:range :Action .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasAgent
:hasAgent rdf:type owl:ObjectProperty ;
          rdfs:domain :Policy ;
          rdfs:range :Agent .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasAlignmentState
:hasAlignmentState rdf:type owl:ObjectProperty ;
                   rdfs:domain :Expression ,
                               :ReferenceNode ,
                               :SQLNode ,
                               :Statement ;
                   rdfs:range :AccessAlignmentState .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasChildNode
:hasChildNode rdf:type owl:ObjectProperty ;
              owl:inverseOf :hasParentNode ;
              rdf:type owl:TransitiveProperty ;
              rdfs:domain :SQLNode ;
              rdfs:range :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasClause
:hasClause rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasChildNode ;
           rdfs:domain :SQLNode ,
                       :Statement ;
           rdfs:range :Clause ,
                      :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasColumn
:hasColumn rdf:type owl:ObjectProperty ;
           rdfs:domain :Object ,
                       :Table ;
           rdfs:range :Column ,
                      :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasEffectiveScope
:hasEffectiveScope rdf:type owl:ObjectProperty ;
                   rdfs:domain :Clause ,
                               :SQLNode ;
                   rdfs:range :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasExpression
:hasExpression rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasChildNode ;
               rdfs:domain :Clause ,
                           :SQLNode ;
               rdfs:range :Expression ,
                          :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasGrantLevel
:hasGrantLevel rdf:type owl:ObjectProperty ;
               rdfs:domain :Policy ;
               rdfs:range :GrantLevel .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasGrantType
:hasGrantType rdf:type owl:ObjectProperty ;
              rdfs:domain :Policy ;
              rdfs:range :GrantType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasNodeType
:hasNodeType rdf:type owl:ObjectProperty ;
             rdfs:domain :SQLNode ;
             rdfs:range :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasParentNode
:hasParentNode rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasRow
:hasRow rdf:type owl:ObjectProperty ;
        rdfs:domain :Object ,
                    :Table ;
        rdfs:range :Object ,
                   :Row .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasScope
:hasScope rdf:type owl:ObjectProperty ;
          rdfs:domain :Action ;
          rdfs:range :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/hasTable
:hasTable rdf:type owl:ObjectProperty ;
          rdfs:domain :Database ,
                      :Object ;
          rdfs:range :Object ,
                     :Table .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/immediateChildNode
:immediateChildNode rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasChildNode ;
                    owl:inverseOf :immediateParentNode ;
                    rdfs:domain :SQLNode ;
                    rdfs:range :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/immediateParentNode
:immediateParentNode rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasParentNode ;
                     rdfs:domain :SQLNode ;
                     rdfs:range :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/oppositeOf
:oppositeOf rdf:type owl:ObjectProperty ,
                     owl:SymmetricProperty .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/referencesToColumn
:referencesToColumn rdf:type owl:ObjectProperty ;
                    rdfs:domain :ColumnRef ,
                                :Expression ,
                                :NonFunctional ,
                                :ReferenceNode ,
                                :SQLNode ,
                                :SQLNodeType ,
                                :Wildcard ;
                    rdfs:range :Column ,
                               :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/referencesToTable
:referencesToTable rdf:type owl:ObjectProperty ;
                   rdfs:domain :Expression ,
                               :NonFunctional ,
                               :ReferenceNode ,
                               :SQLNode ,
                               :SQLNodeType ,
                               :TableRef ;
                   rdfs:range :Object ,
                              :Table .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/representsAction
:representsAction rdf:type owl:ObjectProperty ;
                  rdfs:domain :SQLNode ,
                              :Statement ;
                  rdfs:range :Action .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ColumnName
:ColumnName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Column ,
                        :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/FunctionName
:FunctionName rdf:type owl:DatatypeProperty ;
              rdfs:domain :Expression ,
                          :Function ,
                          :Functional ,
                          :SQLNode ,
                          :SQLNodeType ;
              rdfs:range xsd:string .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/OperationName
:OperationName rdf:type owl:DatatypeProperty ;
               rdfs:domain :Expression ,
                           :NonFunctional ,
                           :Operator ,
                           :SQLNode ,
                           :SQLNodeType ;
               rdfs:range xsd:string .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/TableName
:TableName rdf:type owl:DatatypeProperty ;
           rdfs:domain :Object ,
                       :Table .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Value
:Value rdf:type owl:DatatypeProperty ;
       rdfs:domain :Expression ,
                   :Literal ,
                   :NonFunctional ,
                   :SQLNode ,
                   :SQLNodeType .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/AccessAlignmentState
:AccessAlignmentState rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Action
:Action rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ActionScope
:ActionScope rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Agent
:Agent rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Alias
:Alias rdf:type owl:Class ;
       rdfs:subClassOf :Expression ,
                       :NonFunctional ,
                       :SQLNode ,
                       :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Clause
:Clause rdf:type owl:Class ;
        rdfs:subClassOf :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Column
:Column rdf:type owl:Class ;
        rdfs:subClassOf :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ColumnRef
:ColumnRef rdf:type owl:Class ;
           rdfs:subClassOf :Expression ,
                           :NonFunctional ,
                           :ReferenceNode ,
                           :SQLNode ,
                           :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Database
:Database rdf:type owl:Class ;
          rdfs:subClassOf :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/DeleteStatement
:DeleteStatement rdf:type owl:Class ;
                 rdfs:subClassOf :NonFunctional ,
                                 :SQLNode ,
                                 :SQLNodeType ,
                                 :Statement ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :FromClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :WhereClause
                                 ] .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Expression
:Expression rdf:type owl:Class ;
            rdfs:subClassOf :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/FromClause
:FromClause rdf:type owl:Class ;
            rdfs:subClassOf :Clause ,
                            :NonFunctional ,
                            :SQLNode ,
                            :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Function
:Function rdf:type owl:Class ;
          rdfs:subClassOf :Expression ,
                          :Functional ,
                          :SQLNode ,
                          :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Functional
:Functional rdf:type owl:Class ;
            rdfs:subClassOf :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/GrantLevel
:GrantLevel rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/GrantType
:GrantType rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/GroupByClause
:GroupByClause rdf:type owl:Class ;
               rdfs:subClassOf :Clause ,
                               :NonFunctional ,
                               :SQLNode ,
                               :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/InsertStatement
:InsertStatement rdf:type owl:Class ;
                 rdfs:subClassOf :NonFunctional ,
                                 :SQLNode ,
                                 :SQLNodeType ,
                                 :Statement ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :IntoClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :ValuesClause
                                 ] .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/IntoClause
:IntoClause rdf:type owl:Class ;
            rdfs:subClassOf :Clause ,
                            :NonFunctional ,
                            :SQLNode ,
                            :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/LimitClause
:LimitClause rdf:type owl:Class ;
             rdfs:subClassOf :Clause ,
                             :NonFunctional ,
                             :SQLNode ,
                             :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Literal
:Literal rdf:type owl:Class ;
         rdfs:subClassOf :Expression ,
                         :NonFunctional ,
                         :SQLNode ,
                         :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/NonFunctional
:NonFunctional rdf:type owl:Class ;
               rdfs:subClassOf :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Object
:Object rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Operator
:Operator rdf:type owl:Class ;
          rdfs:subClassOf :Expression ,
                          :NonFunctional ,
                          :SQLNode ,
                          :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Policy
:Policy rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/PolicyCorrectnessStatus
:PolicyCorrectnessStatus rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ReferenceNode
:ReferenceNode rdf:type owl:Class ;
               rdfs:subClassOf :Expression ,
                               :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Row
:Row rdf:type owl:Class ;
     rdfs:subClassOf :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/SQLNode
:SQLNode rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/SQLNodeType
:SQLNodeType rdf:type owl:Class .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/SelectClause
:SelectClause rdf:type owl:Class ;
              rdfs:subClassOf :Clause ,
                              :NonFunctional ,
                              :SQLNode ,
                              :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/SelectStatement
:SelectStatement rdf:type owl:Class ;
                 rdfs:subClassOf :NonFunctional ,
                                 :SQLNode ,
                                 :SQLNodeType ,
                                 :Statement ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :FromClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :GroupByClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :LimitClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :SelectClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :WhereClause
                                 ] .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/SetClause
:SetClause rdf:type owl:Class ;
           rdfs:subClassOf :Clause ,
                           :NonFunctional ,
                           :SQLNode ,
                           :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Statement
:Statement rdf:type owl:Class ;
           rdfs:subClassOf :SQLNode .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Table
:Table rdf:type owl:Class ;
       rdfs:subClassOf :Object .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/TableRef
:TableRef rdf:type owl:Class ;
          rdfs:subClassOf :Expression ,
                          :NonFunctional ,
                          :ReferenceNode ,
                          :SQLNode ,
                          :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/UpdateClause
:UpdateClause rdf:type owl:Class ;
              rdfs:subClassOf :Clause ,
                              :NonFunctional ,
                              :SQLNode ,
                              :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/UpdateStatement
:UpdateStatement rdf:type owl:Class ;
                 rdfs:subClassOf :NonFunctional ,
                                 :SQLNode ,
                                 :SQLNodeType ,
                                 :Statement ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :SetClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :UpdateClause
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :allowsClause ;
                                   owl:someValuesFrom :WhereClause
                                 ] .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ValuesClause
:ValuesClause rdf:type owl:Class ;
              rdfs:subClassOf :Clause ,
                              :NonFunctional ,
                              :SQLNode ,
                              :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/WhereClause
:WhereClause rdf:type owl:Class ;
             rdfs:subClassOf :Clause ,
                             :NonFunctional ,
                             :SQLNode ,
                             :SQLNodeType .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Wildcard
:Wildcard rdf:type owl:Class ;
          rdfs:subClassOf :Expression ,
                          :ReferenceNode ,
                          :SQLNode .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#DeleteActionScope
:DeleteActionScope rdf:type owl:NamedIndividual ,
                            :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#InsertActionScope
:InsertActionScope rdf:type owl:NamedIndividual ,
                            :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#ModifyAction
:ModifyAction rdf:type owl:NamedIndividual ,
                       :Action .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#RowTag
:RowTag rdf:type owl:NamedIndividual ,
                 :AccessAlignmentState .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#UpdateActionScope
:UpdateActionScope rdf:type owl:NamedIndividual ,
                            :ActionScope .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#p0006
:p0006 rdf:type owl:NamedIndividual ,
                :Policy ;
       :appliesToScope :ProcessActionScope ;
       :controlAccessTo :t003 ;
       :hasAction :ReadAction ;
       :hasAgent :a0012 ;
       :hasGrantLevel :RowLevel ;
       :hasGrantType :PermissionGrant .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#p0007
:p0007 rdf:type owl:NamedIndividual ,
                :Policy ;
       :appliesToScope :InsertActionScope ;
       :controlAccessTo :t008 ;
       :hasAction :ModifyAction ;
       :hasAgent :a0012 ;
       :hasGrantLevel :TableLevel ;
       :hasGrantType :PermissionGrant .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#p0008
:p0008 rdf:type owl:NamedIndividual ,
                :Policy ;
       :appliesToScope :UpdateActionScope ;
       :controlAccessTo :t007 ;
       :hasAction :ModifyAction ;
       :hasAgent :a0012 ;
       :hasGrantLevel :TableLevel ;
       :hasGrantType :PermissionGrant .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf#p0009
:p0009 rdf:type owl:NamedIndividual ,
                :Policy ;
       :appliesToScope :DeleteActionScope ;
       :controlAccessTo :t006 ;
       :hasAction :ModifyAction ;
       :hasAgent :a0012 ;
       :hasGrantLevel :TableLevel ;
       :hasGrantType :PermissionGrant .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/Aligned
:Aligned rdf:type owl:NamedIndividual ,
                  :AccessAlignmentState ;
         :oppositeOf :Violated .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ColumnLevel
:ColumnLevel rdf:type owl:NamedIndividual ,
                      :GrantLevel .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/ConditionalGrant
:ConditionalGrant rdf:type owl:NamedIndividual ,
                           :GrantType ;
                  :allowedGrantLevel :RowLevel .


###  http://www.semanticweb.org/nipun_qk4hy9e/ontologies/2025/5/apuf/DeleteAction
:DeleteAction rdf:type owl:NamedIndividual ,
